nergy)\n    results[f\"{split}_forces\"] = forces\n    results[f\"{split}_chunk_idx\"] = chunk_idx\n\nnp.savez_compressed(\"oc20_s2ef_predictions.npz\", **results)","position":{"start":{"line":49,"column":1},"end":{"line":83,"column":1}},"key":"ROo6oAEirJ"},{"type":"admonition","kind":"warning","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Warning","key":"EBjCxTwkjK"}],"key":"EBtfmzvXpe"},{"type":"paragraph","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"The above example can be very slow on a single GPU and we encourage users to parallelize this however they like. We provide the example as a means to understand the expected format for the leaderboard.","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"LiT7u4CQX3"}],"key":"yzwry8wcYp"}],"key":"KotVNlEvJ2"},{"type":"heading","depth":2,"position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"IS2RE","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"shqFQH1Yq8"}],"identifier":"is2re","label":"IS2RE","html_id":"is2re","implicit":true,"key":"wLyi0CFkhk"},{"type":"paragraph","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Predictions must be saved as “.npz” files containing the following keys for each split (","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"UcsXLFeEsG"},{"type":"inlineCode","value":"id","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"I5j1w284PW"},{"type":"text","value":", ","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"ePx9J9pqrY"},{"type":"inlineCode","value":"ood_ads","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"rdqQe5U9ad"},{"type":"text","value":", ","position":{"start":{"line":91,"column":1},"end":{"line":91,"col