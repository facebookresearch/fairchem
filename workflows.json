{"version":3,"kind":"Notebook","sha256":"d875a080d722e1ff7bf653742649675c6e0624eefecc0d1839d1ee4c7dd22faa","slug":"workflows","location":"/core/common_tasks/workflows.md","dependencies":[],"frontmatter":{"title":"Calculation Workflows with FAIRChem Models","kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"jupytext":{"text_representation":{"extension":".md","format_name":"myst","format_version":"0.13","jupytext_version":"1.17.1"}},"content_includes_title":false,"authors":[{"nameParsed":{"literal":"FAIR Chemistry & Collaborators","given":"FAIR Chemistry &","family":"Collaborators"},"name":"FAIR Chemistry & Collaborators","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/facebookresearch/fairchem","copyright":"Meta Platforms, Inc","numbering":{"title":{"offset":2}},"source_url":"https://github.com/facebookresearch/fairchem/blob/main/docs/core/common_tasks/workflows.md","edit_url":"https://github.com/facebookresearch/fairchem/edit/main/docs/core/common_tasks/workflows.md","exports":[{"format":"md","filename":"workflows.md","url":"/build/workflows-e16d4d51f289a1c99178ceea9ad5ec65.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"This repo is integrated with workflow tools like ","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"NAtcX4ftNh"},{"type":"link","url":"https://github.com/Quantum-Accelerators/quacc","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"QuAcc","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"kgmE0puAG8"}],"urlSource":"https://github.com/Quantum-Accelerators/quacc","error":true,"key":"ncQ45pLbY6"},{"type":"text","value":" to make complex molecular simulation workflows easy. You can use any MLP recipe (relaxations, single-points, elastic calculations, etc.) and simply specify the ","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"BfvAq6ojJB"},{"type":"inlineCode","value":"fairchem","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"zo9vFgEEw3"},{"type":"text","value":" model type.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"pVVdHBc8T6"}],"key":"IqDBLOBSgY"},{"type":"admonition","kind":"tip","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Tip","key":"x1KOgmDow8"}],"key":"yvdkScoqeQ"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"One of the nice things about QuAcc is that you can use plugins for whatever your favorite workflow engine is (Fireworks, Parsl, Prefect, etc.). Some of these methods can scale to hundreds of thousands of parallel calculations and are used by the FAIR chemistry team regularly!","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"N8D5jMTFbr"}],"key":"e8gYfwEifp"}],"key":"Oj1AHglZmt"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Below is an example that uses the default ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"ugItyHwpJL"},{"type":"inlineCode","value":"elastic_tensor_flow","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"wKFOiymBPX"},{"type":"text","value":" flow:","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"akp0LVxPRT"}],"key":"oaAOoIn0Xk"}],"key":"IJ65WIJ0VA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\nfrom ase.build import bulk\nfrom quacc.recipes.mlp.elastic import elastic_tensor_flow\n\n# Make an Atoms object of a bulk Cu structure\natoms = b