k at the frame set prior to optimization and the optimized frame set, you could get them like this:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"YcvQukUhw9"}],"key":"NW6jUyd1ls"}],"key":"cnv5J1sWY1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\n!wget https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\n\nfrom ase.io import read\n\ntraj = read(\"desorption_id_83_2409_9_111-4_neb1.0.traj\", \":\")\nunrelaxed_frames = traj[0:10]\nrelaxed_frames = traj[-10:]","key":"HSXLRATm5v"},{"type":"outputs","id":"Pm4BLoBEeDgu7OUC1yzQh","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"--2026-03-06 20:51:10--  https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\r\n"},"key":"N0gTX3Ey0z"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Resolving dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)... "},"key":"lOqKNOpqVN"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"3.171.22.33, 3.171.22.118, 3.171.22.13, ...\r\nConnecting to dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)|3.171.22.33|:443... connected.\r\nHTTP request sent, awaiting response... "},"key":"Cds3G6V0K1"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"200 OK\r\nLength: 10074935 (9.6M) [binary/octet-stream]\r\nSaving to: ‘desorption_id_83_2409_9_111-4_neb1.0.traj’\r\n\r\n\r          desorptio   0%[                    ]       0  --.-KB/s               "},"key":"yqbxbGoarg"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\r         desorption   7%[>                   ] 756.99K  3.64MB/s               "},"key":"nGXeDCU4zC"},{"type":"output