k at the frame set prior to optimization and the optimized frame set, you could get them like this:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"rKhCGRep0x"}],"key":"haBXDzvip8"}],"key":"u7YQadRPWC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\n!wget https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\n\nfrom ase.io import read\n\ntraj = read(\"desorption_id_83_2409_9_111-4_neb1.0.traj\", \":\")\nunrelaxed_frames = traj[0:10]\nrelaxed_frames = traj[-10:]","key":"LIsfgd4Pl6"},{"type":"outputs","id":"I8LZ6YTe4QaxLk4M38DCM","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"--2026-03-06 05:39:22--  https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\r\n"},"key":"B5BDymu86N"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Resolving dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)... 65.8.54.85, 65.8.54.65, 65.8.54.33, ...\r\nConnecting to dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)|65.8.54.85|:443... connected.\r\n"},"key":"RZsCNjIAt8"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"HTTP request sent, awaiting response... "},"key":"yAq0xkEPiL"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"200 OK\r\nLength: 10074935 (9.6M) [binary/octet-stream]\r\nSaving to: ‘desorption_id_83_2409_9_111-4_neb1.0.traj’\r\n\r\n\r          desorptio   0%[                    ]       0  --.-KB/s               "},"key":"f4rlvDK3ZH"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\rdesorption_id_83_24 100%[===================>]   9.61M  54.7MB/s    in 0.2s    \r\n\r\n2026-03-06 05:39:23 (54.7 MB/s) - ‘