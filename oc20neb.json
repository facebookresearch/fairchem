k at the frame set prior to optimization and the optimized frame set, you could get them like this:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"oKwG3B5efS"}],"key":"RCg5SxVIoT"}],"key":"lHi3WC4j4L"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\n!wget https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\n\nfrom ase.io import read\n\ntraj = read(\"desorption_id_83_2409_9_111-4_neb1.0.traj\", \":\")\nunrelaxed_frames = traj[0:10]\nrelaxed_frames = traj[-10:]","key":"d18xDpPXxo"},{"type":"outputs","id":"HvUVQPf7lcTM5eHZMsS70","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"--2026-05-29 13:48:35--  https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\r\nResolving dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)... "},"key":"QDektXcWEw"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"3.171.22.33, 3.171.22.118, 3.171.22.68, ...\r\nConnecting to dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)|3.171.22.33|:443... connected.\r\nHTTP request sent, awaiting response... "},"key":"PT1ovqr4RK"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"200 OK\r\nLength: 10074935 (9.6M) [binary/octet-stream]\r\nSaving to: ‘desorption_id_83_2409_9_111-4_neb1.0.traj’\r\n\r\n\r          desorptio   0%[                    ]       0  --.-KB/s               "},"key":"BkUhSmVa9J"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\r         desorption   7%[>                   ] 731.18K  3.11MB/s               "},"key":"uGZ6ADxqt5"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\rdesorption_id_83_24 100%[===========