re information, check out the paper.","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"hs1Ltrr1sZ"}],"key":"XDeAwbSHoB"},{"type":"heading","depth":2,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"File Structure and Contents","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"YWcxx0VoZq"}],"identifier":"file-structure-and-contents","label":"File Structure and Contents","html_id":"file-structure-and-contents","implicit":true,"key":"ETz5vqxIdJ"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"The tar file contains 3 subdirectories: dissociations, desorptions, and transfers. As the names imply, these directories contain the converged DFT trajectories for each of the reaction classes. Within these directories, the trajectories are named to identify the contents of the file. Here is an example and the anatomy of the name:","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"BB4LaPgT4h"}],"key":"Ut1N3BAB4A"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"inlineCode","value":"desorption_id_83_2409_9_111-4_neb1.0.traj","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"hCjEqvhBZ4"}],"key":"jUbFsM5qQ7"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":36,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"desorption","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"MDkJqJogQU"},{"type":"text","value":" indicates the reaction type (dissociation and transfer are the other possibilities)","position":{"start":{"line"