k at the frame set prior to optimization and the optimized frame set, you could get them like this:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"Rr7gveAJkt"}],"key":"SGzUkiuBhO"}],"key":"hVFacxo9hj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\n!wget https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\n\nfrom ase.io import read\n\ntraj = read(\"desorption_id_83_2409_9_111-4_neb1.0.traj\", \":\")\nunrelaxed_frames = traj[0:10]\nrelaxed_frames = traj[-10:]","key":"UDspCn1TnS"},{"type":"outputs","id":"j_gT7MBy95wgVrkEtx6z5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"--2026-03-03 18:52:24--  https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\r\n"},"key":"elUunhT5ux"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Resolving dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)... 65.8.54.85, 65.8.54.33, 65.8.54.65, ...\r\nConnecting to dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)|65.8.54.85|:443... connected.\r\n"},"key":"Bqwdcaq3cq"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"HTTP request sent, awaiting response... "},"key":"TAgnhvsfBF"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"200 OK\r\nLength: 10074935 (9.6M) [binary/octet-stream]\r\nSaving to: ‘desorption_id_83_2409_9_111-4_neb1.0.traj’\r\n\r\n\r          desorptio   0%[                    ]       0  --.-KB/s               "},"key":"brEFfo4pCQ"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\r         desorption  69%[============>       ]   6.69M  27.8MB/s               "},"key":"IHbLzkzmdC"},{"type":"output","ch