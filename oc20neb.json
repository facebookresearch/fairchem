k at the frame set prior to optimization and the optimized frame set, you could get them like this:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"GTvmJ1AXt0"}],"key":"hJbf6MnXlt"}],"key":"hkF2zpdG40"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from __future__ import annotations\n\n!wget https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\n\nfrom ase.io import read\n\ntraj = read(\"desorption_id_83_2409_9_111-4_neb1.0.traj\", \":\")\nunrelaxed_frames = traj[0:10]\nrelaxed_frames = traj[-10:]","key":"QcoIRjv6ym"},{"type":"outputs","id":"UO1Ul6Zb9ZZjLf5mzoJAv","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"--2026-04-06 18:45:23--  https://dl.fbaipublicfiles.com/opencatalystproject/data/large_files/desorption_id_83_2409_9_111-4_neb1.0.traj\r\n"},"key":"a4Qvkb9W5x"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Resolving dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)... "},"key":"yShLq9k9gH"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"3.171.22.118, 3.171.22.13, 3.171.22.68, ...\r\nConnecting to dl.fbaipublicfiles.com (dl.fbaipublicfiles.com)|3.171.22.118|:443... connected.\r\nHTTP request sent, awaiting response... "},"key":"Ti6YW4BcNG"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"200 OK\r\nLength: 10074935 (9.6M) [binary/octet-stream]\r\nSaving to: ‘desorption_id_83_2409_9_111-4_neb1.0.traj’\r\n\r\n\r          desorptio   0%[                    ]       0  --.-KB/s               "},"key":"WdwernLD2V"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"\r         desorption   7%[>                   ] 748.20K  3.61MB/s               "},"key":"nsURCQZiOM"},{"type":"outpu