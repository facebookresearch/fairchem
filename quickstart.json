},"end":{"line":179,"column":1}},"key":"pPOQry8x1p"},{"type":"heading","depth":2,"position":{"start":{"line":181,"column":1},"end":{"line":181,"column":1}},"children":[{"type":"text","value":"Relax an inorganic crystal","position":{"start":{"line":181,"column":1},"end":{"line":181,"column":1}},"key":"Ix3X4ok70e"}],"identifier":"relax-an-inorganic-crystal","label":"Relax an inorganic crystal","html_id":"relax-an-inorganic-crystal","implicit":true,"key":"LYSCsq3V4W"},{"type":"code","lang":"python","value":"from ase.build import bulk\nfrom ase.optimize import FIRE\nfrom ase.filters import FrechetCellFilter\nfrom fairchem.core import pretrained_mlip, FAIRChemCalculator\n\npredictor = pretrained_mlip.get_predict_unit(\"uma-s-1p2\", device=\"cuda\")\ncalc = FAIRChemCalculator(predictor, task_name=\"omat\")\n\natoms = bulk(\"Fe\")\natoms.calc = calc\n\nopt = LBFGS(FrechetCellFilter(atoms))\nopt.run(0.05, 100)","position":{"start":{"line":183,"column":1},"end":{"line":197,"column":1}},"key":"HH5bajvw59"},{"type":"heading","depth":2,"position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"children":[{"type":"text","value":"Run molecular MD","position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"key":"n8sYYID6LV"}],"identifier":"run-molecular-md","label":"Run molecular MD","html_id":"run-molecular-md","implicit":true,"key":"LlQP8J0lfz"},{"type":"code","lang":"python","value":"from ase import units\nfrom ase.io import Trajectory\nfrom ase.md.langevin import Langevin\nfrom ase.build import molecule\nfrom fairchem.core import pretrained_mlip, FAIRChemCalculator\n\npredictor = pretrained_mlip.get_predict_unit(\"uma-s-1p2\", device=\"cuda\")\ncalc = FAIRChemCalculator(predictor, task_name=\"omol\")\n\natoms = molecule(\"H2O\")\natoms.calc = calc\n\ndyn = Langevin(\n    atoms,\n    timestep=0.1 * units.fs,\n    temperature_K=400,\n    friction=0.001 / units.fs,\n)\ntrajectory = Trajectory(\"my_md.traj\", \"w\", atoms)\ndyn.attach(trajectory.w