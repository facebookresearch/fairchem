dict_unit(\"uma-s-1p1\", device=\"cuda\")\ncalc = FAIRChemCalculator(predictor, task_name=\"omat\")\n\natoms = bulk(\"Fe\")\natoms.calc = calc\n\nopt = LBFGS(FrechetCellFilter(atoms))\nopt.run(0.05, 100)","position":{"start":{"line":155,"column":1},"end":{"line":169,"column":1}},"key":"giSNPDLuUc"},{"type":"heading","depth":2,"position":{"start":{"line":171,"column":1},"end":{"line":171,"column":1}},"children":[{"type":"text","value":"Run molecular MD","position":{"start":{"line":171,"column":1},"end":{"line":171,"column":1}},"key":"qWVNF426YG"}],"identifier":"run-molecular-md","label":"Run molecular MD","html_id":"run-molecular-md","implicit":true,"key":"OYZR2BRA21"},{"type":"code","lang":"python","value":"from ase import units\nfrom ase.io import Trajectory\nfrom ase.md.langevin import Langevin\nfrom ase.build import molecule\nfrom fairchem.core import pretrained_mlip, FAIRChemCalculator\n\npredictor = pretrained_mlip.get_predict_unit(\"uma-s-1p1\", device=\"cuda\")\ncalc = FAIRChemCalculator(predictor, task_name=\"omol\")\n\natoms = molecule(\"H2O\")\natoms.calc = calc\n\ndyn = Langevin(\n    atoms,\n    timestep=0.1 * units.fs,\n    temperature_K=400,\n    friction=0.001 / units.fs,\n)\ntrajectory = Trajectory(\"my_md.traj\", \"w\", atoms)\ndyn.attach(trajectory.write, interval=1)\ndyn.run(steps=1000)","position":{"start":{"line":173,"column":1},"end":{"line":195,"column":1}},"key":"MME4U2gg84"},{"type":"heading","depth":2,"position":{"start":{"line":197,"column":1},"end":{"line":197,"column":1}},"children":[{"type":"text","value":"Calculate a spin gap","position":{"start":{"line":197,"column":1},"end":{"line":197,"column":1}},"key":"VzAQaCCoJS"}],"identifier":"calculate-a-spin-gap","label":"Calculate a spin gap","html_id":"calculate-a-spin-gap","implicit":true,"key":"ur61Jk58Am"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"lV0eWpluhA"}],"key":"S21EM5gwnV"},{"type":"paragraph","positio